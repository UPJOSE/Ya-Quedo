            "url": "{{base_url}}/api/reviews",
            "body": { "mode":"raw","raw": "{\n  \"solicitudId\": \"{{solicitud_finalizada_id}}\",\n  \"puntuacion\": 5,\n  \"comentario\": \"Excelente, super recomendado\"\n}" }
          }
        },
        {
          "name": "GET /api/reviews/trabajador/{trabajadorId} · resenas de Luis",
